# ============================================================
# .env.secrets.example — Secrets template
# ============================================================
# Copy to .env.secrets and fill in real values, OR run
# ./init-secrets.sh to auto-generate strong passwords.
#
#   cp .env.secrets.example .env.secrets
#
# .env.secrets is gitignored — NEVER commit it.
# ============================================================

# ── Broker Credentials ──────────────────────────────────────
REDIS_PASSWORD=<your-redis-password>
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=<your-rabbitmq-password>

# ── ASGI / Django Channels (only needed when ASGI_MODE=true) ─
CHANNELS_REDIS_PASSWORD=<your-channels-redis-password>

# ── Flower Dashboard ────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=<your-flower-password>

# ── Grafana ─────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=<your-grafana-password>

# ── Alerting Integrations ───────────────────────────────────
SLACK_WEBHOOK_URL=<replace-with-slack-webhook-url>
PAGERDUTY_INTEGRATION_KEY=<replace-with-pagerduty-key>

# ── Email Credentials ───────────────────────────────────────
EMAIL_HOST_PASSWORD=<your-smtp-password>

# ── Media Volume Path ───────────────────────────────────────
# Absolute path on the host where your Django project's media
# files are stored. Mounted into the critical worker container.
MEDIA_VOLUME_PATH=/mnt/media
