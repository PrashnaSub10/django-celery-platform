# .celery-profile.env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file, fill in the required values, and pass it to the launcher:
#
#   cp .celery-profile.env.example /path/to/my-project/celery-profile.env
#   nano /path/to/my-project/celery-profile.env
#
#   MODE=standard BROKER_MODE=redis SERVER_PROFILE=medium \
#     PROJECT_PROFILE=/path/to/my-project/celery-profile.env \
#     ./core/up.sh
#
# ─────────────────────────────────────────────────────────────────────────────
# DIMENSION 6 — CODE_SOURCE: how your Django project code reaches the workers
# ─────────────────────────────────────────────────────────────────────────────
# Choose ONE mode that matches how your Django project is deployed:
#
#  bind   (default) — bind-mount APP_PATH from the Docker host at /app.
#                     Use when Django runs as a systemd/systemd service or
#                     directly on the host (bare metal, VM, local dev).
#
#  image            — code is baked into WORKER_IMAGE via COPY at build time.
#                     Use when you maintain a custom worker image that
#                     already contains your project. No APP_PATH needed.
#
#  volume           — mount a named Docker volume at /app.
#                     Use when Django is itself containerised and shares a
#                     code volume with the workers.
#
#  git              — clone APP_GIT_URL into /app at container start.
#                     Use for cloud deployments, CI/CD pipelines, or any
#                     environment where the host filesystem is unavailable.
#                     Subsequent container starts do `git pull` instead of clone.
#
#  pip              — `pip install APP_PIP_PACKAGE` at container start.
#                     Use when your Django project is distributed as a PyPI
#                     package.  The Celery app is imported from site-packages.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: identity ────────────────────────────────────────────────────────

# Short identifier for your project — used to name containers and volumes.
PROJECT_NAME=my-app

# Docker image tag for the worker containers.
# Options:
#   celery-microservice:base   — Python + Celery + Redis client + Flower only
#   celery-microservice:mssql  — + pyodbc / SQL Server drivers
#   celery-microservice:pdf    — + WeasyPrint / Pillow / image processing
#   celery-microservice:smb    — + pysmb / paramiko (SMB/SFTP file shares)
#   celery-microservice:full   — all capability layers (legacy; prefer specific tags)
WORKER_IMAGE=celery-microservice:base

# ── Code delivery (CODE_SOURCE) ───────────────────────────────────────────────

# Select one of: bind | image | git | volume | pip
CODE_SOURCE=bind

# CODE_SOURCE=bind — path on the Docker host to your Django project root.
# The worker mounts this at /app so Python can import your modules.
APP_PATH=/absolute/path/to/your/django-project

# CODE_SOURCE=volume — name of the Docker volume that contains your project.
# The volume must be created externally (by your Django app's compose stack).
# APP_VOLUME_NAME=my_app_code

# CODE_SOURCE=git — Git repository URL to clone at container start.
# Subsequent starts run `git pull --ff-only` instead of a fresh clone.
# For private repos inject credentials via the URL:
#   APP_GIT_URL=https://token:${GITHUB_TOKEN}@github.com/your-org/repo.git
# APP_GIT_URL=https://github.com/your-org/your-django-project.git
# APP_GIT_BRANCH=main   # optional; defaults to the repo's default branch

# CODE_SOURCE=pip — PyPI package (or VCS reference) that installs your project.
# APP_PIP_PACKAGE=your-django-project==1.2.3

# ── Celery app entrypoints ────────────────────────────────────────────────────
# Dotted module:attribute path to the Celery app object.
# For CODE_SOURCE=pip: use the installed package's module path.
# For CODE_SOURCE=bind/volume/git/image: path relative to your project root.
# See docs/DEVELOPER_GUIDE.md Step 2 for per-BROKER_MODE wiring instructions.

# Required for BROKER_MODE=redis or BROKER_MODE=hybrid
CELERY_APP_REDIS=config.celery_redis:app

# Required for BROKER_MODE=rabbitmq or BROKER_MODE=hybrid
CELERY_APP_RABBITMQ=config.celery_rabbitmq:app

# Required for BROKER_MODE=kafka
# CELERY_APP_KAFKA=config.celery_kafka:app

# ── Queue names ───────────────────────────────────────────────────────────────
# Must match task_default_queue in broker_settings.py (or your override).
CELERY_REDIS_QUEUE=redis_queue
CELERY_RABBITMQ_QUEUE=rabbitmq_queue
# CELERY_KAFKA_QUEUE=kafka_queue

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=yourdomain.com

# ── Optional: concurrency override ────────────────────────────────────────────
# Uncomment to enable concurrency > 1 for the critical worker pool.
# CRITICAL_POOL=prefork

# ── Optional: runtime pip injection (development only) ────────────────────────
# Installs extra packages into the worker at container start.
# Requires ALLOW_RUNTIME_PIP=true — do NOT enable in production.
# For production, build a custom image or use CODE_SOURCE=git/pip.
# EXTRA_PIP_PACKAGES=pysmb==1.2.13 paramiko==3.4.0
# ALLOW_RUNTIME_PIP=false
