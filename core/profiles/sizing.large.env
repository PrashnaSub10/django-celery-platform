SERVER_PROFILE=large

# ── Concurrency & Performance ──
FAST_CONCURRENCY=150
# NOTE: CRITICAL_CONCURRENCY > 1 requires CRITICAL_POOL=prefork (not solo).
# Set CRITICAL_POOL=prefork in your celery-profile.env to use concurrency=4.
CRITICAL_CONCURRENCY=4

# ── Memory Constraints ──
FAST_MAX_MEMORY=500000       # ~500MB
CRITICAL_MAX_MEMORY=1000000  # ~1GB

# WHY: Designed for 8+ CPUs and 16GB+ RAM.
# High throughput, hybrid workloads. Full exporter overhead allowed.
