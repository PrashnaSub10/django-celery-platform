SERVER_PROFILE=small

# ── Concurrency & Performance ──
FAST_CONCURRENCY=10
CRITICAL_CONCURRENCY=1

# ── Memory Constraints ──
FAST_MAX_MEMORY=100000       # ~100MB
CRITICAL_MAX_MEMORY=150000   # ~150MB

# WHY: Designed for 1-2 CPUs and 2-4GB RAM.
# Focused on strict limits. Use only Redis for broker.
