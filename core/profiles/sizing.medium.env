SERVER_PROFILE=medium

# ── Concurrency & Performance ──
FAST_CONCURRENCY=50
# NOTE: CRITICAL_CONCURRENCY > 1 requires CRITICAL_POOL=prefork (not solo).
# solo pool always runs 1 task at a time regardless of this value.
# Set CRITICAL_POOL=prefork in your celery-profile.env to use concurrency=2.
CRITICAL_CONCURRENCY=2

# ── Memory Constraints ──
FAST_MAX_MEMORY=200000       # ~200MB
CRITICAL_MAX_MEMORY=300000   # ~300MB

# WHY: Designed for 4 CPUs and 8GB RAM.
# Balanced performance. Optionally add RabbitMQ.
