# ============================================================
# .env.example — Copy to .env.secrets and fill in real values
# Run ./init-secrets.sh to auto-generate strong passwords.
# ============================================================

# Redis
REDIS_PASSWORD=<change_me>

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=<change_me>

# Flower
FLOWER_USER=admin
FLOWER_PASSWORD=<change_me>

# Grafana
GF_SECURITY_ADMIN_PASSWORD=<change_me>

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=yourdomain.com

# Alerting integrations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<change_me>
PAGERDUTY_INTEGRATION_KEY=<change_me>

# Email (used by Alertmanager SMTP fallback)
EMAIL_HOST_PASSWORD=<change_me>
