# WORKER_MODE is read by up.sh to select this strategy file.
# It is NOT injected into containers — it is a launcher-only variable.
WORKER_MODE=single

# WHY: Single-worker mode runs one worker pool matched to the
# selected BROKER_MODE (worker-fast for redis, worker-critical
# for rabbitmq).  Use when workloads are homogeneous and you
# do not need simultaneous fast + critical processing.
#
# Compatible with: BROKER_MODE=redis | rabbitmq | hybrid
# When used with BROKER_MODE=hybrid, both worker-fast and
# worker-critical run but there is no unified Flower UI.
