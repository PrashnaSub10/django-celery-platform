# WORKER_MODE is read by up.sh to select this strategy file.
# It is NOT injected into containers — it is a launcher-only variable.
WORKER_MODE=dual

# WHY: Dual-worker mode runs BOTH worker-fast (Redis + gevent)
# and worker-critical (RabbitMQ + solo) with a unified Flower
# instance at :5557 that monitors both pools simultaneously.
# A single hybrid Beat process replaces the per-broker Beat.
#
# Requires: BROKER_MODE=hybrid
# up.sh enforces this — dual mode with a non-hybrid broker
# exits with an error.
#
# Scales down celery-beat from docker-compose.workers.yml to
# prevent two Beat processes running against the same schedule
# database.  worker-hybrid-beat from docker-compose.dual-workers.yml
# takes over scheduling for both brokers.
