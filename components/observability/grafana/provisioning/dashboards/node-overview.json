{
  "title": "Node Overview",
  "uid": "node-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Memory Usage",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "mem %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Disk Usage (/)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_free_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100",
          "legendFormat": "disk %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "System Uptime",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "expr": "time() - node_boot_time_seconds", "legendFormat": "uptime" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg by (cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu{{ cpu }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Over Time",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "used" },
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "total" },
        { "expr": "node_memory_Cached_bytes", "legendFormat": "cached" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network I/O",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "rx {{ device }}" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])", "legendFormat": "tx {{ device }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "read {{ device }}" },
        { "expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "write {{ device }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ]
}
