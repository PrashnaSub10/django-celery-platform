# ============================================================
# .docker.env — Non-secret container configuration
# ============================================================
# SECRETS (passwords, keys, creds) belong in .env.secrets ONLY.
# This file is safe to commit to version control.
# ============================================================

# ============================================
# CONTAINER CONFIGURATION
# ============================================
COMPOSE_PROJECT_NAME=django-celery-platform
CONTAINER_ENV=true

# ============================================
# REDIS CONFIGURATION (non-secret)
# ============================================
REDIS_HOST=celery-redis-shared
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ============================================
# RABBITMQ CONFIGURATION (non-secret)
# ============================================
RABBITMQ_HOST=celery-rabbitmq-shared
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_VHOST=/

# ============================================
# KAFKA CONFIGURATION (non-secret)
# ============================================
KAFKA_HOST=celery-kafka-shared
KAFKA_PORT=9092
KAFKA_NUM_PARTITIONS=3
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_MESSAGE_MAX_BYTES=1048576

# Kafka Worker
CELERY_KAFKA_WORKER_CONCURRENCY=4
CELERY_KAFKA_WORKER_POOL=prefork
CELERY_KAFKA_WORKER_PREFETCH_MULTIPLIER=1
CELERY_KAFKA_WORKER_MAX_TASKS_PER_CHILD=500

# ============================================
# CELERY WORKER DEFAULTS
# ============================================

# Fast Worker (Redis + Gevent)
CELERY_FAST_WORKER_CONCURRENCY=100
CELERY_FAST_WORKER_POOL=gevent
CELERY_FAST_WORKER_PREFETCH_MULTIPLIER=4
CELERY_FAST_WORKER_MAX_TASKS_PER_CHILD=1000

# Critical Worker (RabbitMQ + Solo)
CELERY_CRITICAL_WORKER_CONCURRENCY=1
CELERY_CRITICAL_WORKER_POOL=solo
CELERY_CRITICAL_WORKER_PREFETCH_MULTIPLIER=1
CELERY_CRITICAL_WORKER_MAX_TASKS_PER_CHILD=100

# ============================================
# RESULT BACKEND
# ============================================
# Controls where Celery stores task results.
# Options: redis (default) | django-db | postgres | none
#   redis     — Redis DB 1 (same host as broker, different DB)
#   django-db — django-celery-results package (stores in Django DB)
#   postgres  — Direct PostgreSQL via DATABASE_URL env var
#   none      — Disables result storage entirely
RESULT_BACKEND=redis

# ============================================
# DJANGO CONFIGURATION (non-secret)
# ============================================
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=${DJANGO_ALLOWED_HOSTS:-localhost}
DJANGO_LOG_LEVEL=INFO

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:9500

# ============================================
# NGINX CONFIGURATION
# ============================================
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_PROXY_READ_TIMEOUT=300
NGINX_PROXY_CONNECT_TIMEOUT=300
NGINX_RATE_LIMIT=10r/s
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
NGINX_MTLS_MODE=optional

# ============================================
# DJANGO UPSTREAM (for Nginx proxy)
# ============================================
# Override these per-project in celery-profile.env
# On Linux, host.docker.internal does not resolve by default.
# Add extra_hosts: ["host.docker.internal:host-gateway"] to your
# Django service in docker-compose, or set this to your host's
# LAN IP (e.g. 192.168.1.x) when running on Linux.
DJANGO_UPSTREAM_HOST=host.docker.internal
DJANGO_UPSTREAM_PORT=9845

# ============================================
# MONITORING CONFIGURATION
# ============================================

# Prometheus
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_SCRAPE_INTERVAL=15s
METRICS_TARGET_HOST=host.docker.internal
# NOTE: On Linux, host.docker.internal requires extra_hosts in the
# Prometheus compose service. See components/observability/INTERFACE.md.
METRICS_TARGET_PORT=9845

# Grafana
GRAFANA_INSTALL_PLUGINS=
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_DISABLE_GRAVATAR=true

# Flower
FLOWER_PORT_REDIS=5555
FLOWER_PORT_RABBITMQ=5556
FLOWER_PORT_HYBRID=5557
FLOWER_PORT_KAFKA=5558
FLOWER_MAX_TASKS=10000
FLOWER_PURGE_OFFLINE_WORKERS=3600

# ============================================
# HOST PORT OVERRIDES
# ============================================
# Override any host-side port to avoid collisions on your host.
# Defaults match the platform's documented port map.
# Internal-only ports are bound to 127.0.0.1 (not externally
# reachable) but can still be remapped if another service
# occupies the default port.
#
# Gateway ports (NGINX_HTTP_PORT, NGINX_HTTPS_PORT) and Flower
# ports (FLOWER_PORT_REDIS, etc.) are already overridable above.
PORT_REDIS=6379
PORT_RABBITMQ=5672
PORT_RABBITMQ_MGMT=15672
PORT_KAFKA=9092
PORT_PROMETHEUS=9090
PORT_GRAFANA=8300
PORT_ALERTMANAGER=9093
PORT_REDIS_EXPORTER=9121
PORT_RABBITMQ_EXPORTER=9419
PORT_CELERY_EXPORTER_REDIS=9808
PORT_CELERY_EXPORTER_RABBITMQ=9809
PORT_NODE_EXPORTER=9100
PORT_NGINX_EXPORTER=9113

# ============================================
# NETWORK CONFIGURATION
# ============================================
CELERY_NETWORK_SUBNET=10.220.220.0/24

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=/var/log/app

# ============================================
# PATHS
# ============================================
APP_LOG_PATH=/var/log/app
APP_DATA_PATH=/var/data/app
APP_TEMP_PATH=/tmp/app

# ============================================
# TIMEZONE
# ============================================
TZ=UTC

# ============================================
# HEALTH CHECK CONFIGURATION
# ============================================
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40s

# ============================================
# RESOURCE LIMITS (Optional — uncomment to set)
# ============================================
# REDIS_MEMORY_LIMIT=2g
# REDIS_CPU_LIMIT=2
# RABBITMQ_MEMORY_LIMIT=2g
# RABBITMQ_CPU_LIMIT=2
# WORKER_MEMORY_LIMIT=1g
# WORKER_CPU_LIMIT=1

# ============================================
# ALERTING INTEGRATIONS (secrets go in .env.secrets)
# ============================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<change_me>
# PAGERDUTY_INTEGRATION_KEY=<change_me>

# ============================================
# EMAIL CONFIGURATION (non-secret parts only)
# ============================================
# Credentials (EMAIL_HOST_PASSWORD) are in .env.secrets
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yourdomain.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
DEFAULT_FROM_EMAIL=Your App <noreply@yourdomain.com>
SYS_ADMIN_EMAIL=admin@yourdomain.com
